{
  "name": "market-research",
  "description": "Financial market data \u2014 stocks, SEC filings, macro, options, earnings. Discovery + Code Mode execution via FMP, Polygon, FRED APIs.",
  "version": "0.1.4",
  "author": {
    "name": "digibugcat"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "finance",
    "stocks",
    "market-data"
  ],
  "mcpServers": {
    "market-research": {
      "type": "http",
      "url": "https://market-research.cassandrasedge.com/mcp",
      "headersHelper": "cass ensure-key --header market-research"
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/ensure-cass.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
