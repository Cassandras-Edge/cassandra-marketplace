{
  "name": "perplexity-mcp",
  "description": "Perplexity \u2014 web search, grounded AI answers, step-by-step reasoning. No credentials needed.",
  "version": "0.1.4",
  "author": {
    "name": "digibugcat"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "perplexity",
    "search",
    "research"
  ],
  "mcpServers": {
    "perplexity-mcp": {
      "type": "http",
      "url": "https://perplexity.cassandrasedge.com/mcp",
      "headersHelper": "cass ensure-key --header perplexity-mcp"
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/ensure-cass.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
