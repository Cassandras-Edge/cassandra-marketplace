{
  "name": "media-mcp",
  "description": "YouTube/media \u2014 transcription (GPU ASR + diarization), YouTube search, channel browsing, comments, Watch Later sync.",
  "version": "0.1.6",
  "author": {
    "name": "digibugcat"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "youtube",
    "transcription",
    "media"
  ],
  "mcpServers": {
    "yt-mcp": {
      "type": "http",
      "url": "https://youtube.cassandrasedge.com/mcp",
      "headersHelper": "cass ensure-key --header yt-mcp"
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/ensure-cass.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/ensure-cookies.sh yt-mcp",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
