{
  "name": "twitter-mcp",
  "description": "Twitter/X \u2014 news search, Grok AI synthesis, post analytics, personal timeline, bookmarks. Read-only.",
  "version": "0.1.5",
  "author": {
    "name": "digibugcat"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "twitter",
    "x",
    "news",
    "social"
  ],
  "mcpServers": {
    "twitter-mcp": {
      "type": "http",
      "url": "https://twitter-mcp.cassandrasedge.com/mcp",
      "headersHelper": "cass ensure-key --header twitter-mcp"
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/ensure-cass.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/ensure-cookies.sh twitter",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
