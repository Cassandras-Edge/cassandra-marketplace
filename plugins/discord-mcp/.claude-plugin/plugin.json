{
  "name": "discord-mcp",
  "description": "Discord \u2014 search messages, read channels/threads/DMs, download attachments. Per-user bridge isolation. Read-only.",
  "version": "0.1.4",
  "author": {
    "name": "digibugcat"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "discord",
    "chat",
    "messages"
  ],
  "mcpServers": {
    "discord-mcp": {
      "type": "http",
      "url": "https://discord-mcp.cassandrasedge.com/mcp",
      "headersHelper": "cass ensure-key --header discord-mcp"
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/ensure-cass.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
