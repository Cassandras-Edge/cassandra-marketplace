{
  "name": "gemini-mcp",
  "description": "Gemini \u2014 grounded web search and Q&A with stateful conversations. Auto-searches Google when needed.",
  "version": "0.1.4",
  "author": {
    "name": "digibugcat"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "gemini",
    "search",
    "research",
    "grounding"
  ],
  "mcpServers": {
    "gemini-mcp": {
      "type": "http",
      "url": "https://gemini.cassandrasedge.com/mcp",
      "headersHelper": "cass ensure-key --header gemini-mcp"
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/ensure-cass.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
