{
  "name": "gateway-mcp",
  "description": "Cassandra Gateway \u2014 execute any platform tool via sandboxed Python. Authenticates via WorkOS OAuth.",
  "version": "0.1.4",
  "author": {
    "name": "digibugcat"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "gateway",
    "execute"
  ],
  "mcpServers": {
    "cassandra-gateway": {
      "type": "http",
      "url": "https://gateway.cassandrasedge.com/mcp",
      "headersHelper": "cass ensure-key --header gateway"
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/ensure-cass.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
