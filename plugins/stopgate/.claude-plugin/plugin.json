{
  "name": "stopgate",
  "description": "Stop hook that blocks lazy stops and returns actionable directives. Uses an Opus LLM call to classify whether the assistant actually finished its task.",
  "version": "0.3.2",
  "author": {
    "name": "digibugcat"
  },
  "license": "MIT",
  "keywords": [
    "hooks",
    "stop-gate",
    "agentic",
    "productivity"
  ],
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/stopgate.sh",
            "timeout": 30,
            "statusMessage": "Checking task completion..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/ensure-cass.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/ensure-patched-cli.sh",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
